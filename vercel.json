{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:web",
  "outputDirectory": "apps/stage-web/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    }
  }
}
